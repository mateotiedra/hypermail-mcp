# Core configuration
# Where to store encrypted account data (default: ${XDG_DATA_HOME:-~/.local/share}/hypermail-mcp)
HYPERMAIL_DATA_DIR=

# 32-byte key (base64 or hex), or any passphrase derived with SHA-256.
# Recommended for all deployments. If unset, a local key is generated and persisted.
HYPERMAIL_KEY=

# Runtime transport: stdio (default) or http.
HYPERMAIL_TRANSPORT=stdio
HYPERMAIL_HTTP_PORT=3000
HYPERMAIL_HTTP_HOST=127.0.0.1

# Optional tool filtering. Leave empty to expose all tools.
HYPERMAIL_TOOLS_ENABLED=
HYPERMAIL_TOOLS_DISABLED=

# Outlook / Entra OAuth. Optional; defaults work for local device-code login.
HYPERMAIL_OUTLOOK_CLIENT_ID=
HYPERMAIL_OUTLOOK_TENANT_ID=

# Gmail OAuth client credentials. HYPERMAIL_GMAIL_CLIENT_ID is required when adding Gmail accounts.
HYPERMAIL_GMAIL_CLIENT_ID=
HYPERMAIL_GMAIL_CLIENT_SECRET=
# Optional for hosted HTTP deployments, e.g. https://mail.example.com/oauth/gmail/callback
HYPERMAIL_GMAIL_REDIRECT_URI=

# Optional new-email watcher.
HYPERMAIL_WATCH_ENABLED=false
HYPERMAIL_WATCH_POLL_SECONDS=10
HYPERMAIL_WATCH_WEBHOOK_URL=
HYPERMAIL_WATCH_WEBHOOK_RETRY_ATTEMPTS=5
HYPERMAIL_WATCH_WEBHOOK_RETRY_DELAY_MS=1000
HYPERMAIL_WATCH_NOTIFY_COMMAND=
HYPERMAIL_WATCH_NOTIFY_TIMEOUT_MS=30000
HYPERMAIL_WATCH_NOTIFY_RETRY_ATTEMPTS=5
HYPERMAIL_WATCH_NOTIFY_RETRY_DELAY_MS=1000
