# Where to store encrypted account data (default: ~/.hypermail-mcp)
HYPERMAIL_MCP_DATA_DIR=

# 32-byte key (base64 or hex) used to encrypt the accounts file.
# Required when hosted. If unset locally, a key is generated and persisted
# via OS keychain (keytar) when available.
HYPERMAIL_MCP_KEY=

# Azure AD / Entra public client (application) ID used for device-code auth.
# Defaults to a built-in public client suitable for personal MSA + work accounts.
MS_CLIENT_ID=

# When set to "true", hides the send_email tool — only draft_email is available.
# Drafts can then be reviewed and sent manually from the email client.
HYPERMAIL_DRAFT_ONLY=

# Optional tenant override (default: "common")
MS_TENANT_ID=

# Gmail OAuth client credentials. Use a Desktop client for local loopback auth,
# or a Web client with the redirect URI registered in Google Auth Platform.
HYPERMAIL_PROVIDERS_GMAIL_CLIENT_ID=
HYPERMAIL_PROVIDERS_GMAIL_CLIENT_SECRET=
# Optional for hosted HTTP deployments, e.g. https://mail.example.com/oauth/gmail/callback
HYPERMAIL_PROVIDERS_GMAIL_REDIRECT_URI=
