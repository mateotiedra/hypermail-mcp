{
  "mcpServers": {
    "hypermail": {
      "command": "node",
      "args": [
        "dist/cli.js",
        "--config",
        "hypermail-config.json"
      ],
      "cwd": ".",
      "lifecycle": "lazy",
      "env": {
        "MS_CLIENT_ID": "${MS_CLIENT_ID}",
        "MS_TENANT_ID": "${MS_TENANT_ID}"
      },
      "directTools": true
    }
  }
}
