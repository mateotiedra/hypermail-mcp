{
  "mcpServers": {
    "hypermail": {
      "command": "sh",
      "args": [
        "-c",
        "set -a; [ -f .env ] && . ./.env; set +a; exec node dist/cli.js --config hypermail-config.json"
      ],
      "cwd": ".",
      "lifecycle": "lazy",
      "env": {
        "HYPERMAIL_PROVIDERS_OUTLOOK_CLIENT_ID": "${HYPERMAIL_PROVIDERS_OUTLOOK_CLIENT_ID}",
        "HYPERMAIL_PROVIDERS_OUTLOOK_TENANT_ID": "${HYPERMAIL_PROVIDERS_OUTLOOK_TENANT_ID}",
        "HYPERMAIL_PROVIDERS_GMAIL_CLIENT_ID": "${HYPERMAIL_PROVIDERS_GMAIL_CLIENT_ID}",
        "HYPERMAIL_PROVIDERS_GMAIL_CLIENT_SECRET": "${HYPERMAIL_PROVIDERS_GMAIL_CLIENT_SECRET}"
      },
      "directTools": true
    }
  }
}
