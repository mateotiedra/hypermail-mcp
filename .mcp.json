{
  "mcpServers": {
    "hyper-email": {
      "command": "node",
      "args": [
        "dist/cli.js"
      ],
      "cwd": ".",
      "lifecycle": "lazy",
      "env": {
        "MS_CLIENT_ID": "${MS_CLIENT_ID}",
        "MS_TENANT_ID": "${MS_TENANT_ID}",
        "HYPER_EMAIL_MCP_DATA_DIR": "${HYPER_EMAIL_MCP_DATA_DIR}"
      },
      "directTools": true
    }
  }
}
