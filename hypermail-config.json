{
  "$schema": "https://raw.githubusercontent.com/hypersimple/hypermail-mcp/main/schemas/hypermail-config.schema.json",
  "dataDir": "~/.hypermail-mcp",
  "http": {
    "enabled": false,
    "port": 3000,
    "host": "127.0.0.1"
  },
  "tools": {
    "disabled": []
  },
  "watch": {
    "enabled": true,
    "pollIntervalSeconds": 60,
    "webhook": {
      "url": "${HYPERMAIL_WATCH_WEBHOOK_URL}"
    }
  },
  "providers": {
    "outlook": {
      "clientId": "${MS_CLIENT_ID}",
      "tenantId": "${MS_TENANT_ID}"
    }
  }
}
